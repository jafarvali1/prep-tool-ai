# Docker Config
DB_USER=ai_user
DB_PASSWORD=mypassword
DB_NAME=ai_prep

# If you choose NOT to run docker, and instead just want to run `uvicorn` and `npm run dev` 
# while connecting to your LOCAL MySQL workbench, uncomment this and put it in backend/.env:
# DATABASE_URL=mysql+pymysql://root:YOUR_PASSWORD@localhost:3306/ai_prep
